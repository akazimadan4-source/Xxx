            btn.Text = name .. "  [x]"
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Font = Enum.Font.SourceSans
            btn.TextSize = 13
            btn.Parent = listFrame
            btn.MouseButton1Click:Connect(function()
                -- hapus dari whitelist
                for i, v in ipairs(Settings.Whitelist) do
                    if v == name then
                        table.remove(Settings.Whitelist, i)
                        break
                    end
                end
                refreshWhitelist()
                -- update info
                infoLabel.Text = "Players in range: 0 • Whitelisted: " .. #Settings.Whitelist
            end)
        end
        -- update info
        infoLabel.Text = "Players in range: 0 • Whitelisted: " .. #Settings.Whitelist
    end

