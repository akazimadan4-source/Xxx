--[[
    脚本名称: South Bronx Kill Aura (Wanzz Store 特别版)
    适配游戏: South Bronx: The Trenches
    核心逻辑: 自动寻找远程事件 (RemoteEvent) 进行攻击
]]

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")

-- ===== 用户设置 =====
local Settings = {
    Enabled = false,
    Range = 150,
    Whitelist = {},
    AttackRate = 0.1 -- 攻击间隔（秒）
}

-- ===== 核心攻击函数 (适配 South Bronx) =====
local function Attack(target)
    if not target or not target.Character then return end

    -- 1. 尝试通过远程事件 (RemoteEvent) 攻击
    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("AttackRemote") 
        or game:GetService("ReplicatedStorage"):FindFirstChild("Damage")
        or game:GetService("ReplicatedStorage"):FindFirstChild("Hit")
        or game:GetService("ReplicatedStorage"):FindFirstChild("Combat")
        or game:GetService("ReplicatedStorage"):FindFirstChild("RemoteEvent")
        or game:GetService("ReplicatedStorage"):FindFirstChild("Fire") -- 常见的命名

    if remote then
        -- 尝试发送攻击信号，参数通常是目标的 HumanoidRootPart 或 Humanoid
        pcall(function()
            remote:FireServer(target.Character.HumanoidRootPart)
            remote:FireServer(target.Character) -- 有些游戏需要整个角色
            remote:FireServer(target) -- 有些只需要玩家对象
        end)
    else
        -- 2. 如果没找到 RemoteEvent，则模拟鼠标左键点击（备用方案）
        pcall(function()
            mouse1click()
        end)
    end

    -- 3. 极端情况：如果以上都无效，尝试直接修改血量（部分游戏可用）
    -- pcall(function()
    --     if target.Character and target.Character:FindFirstChild("Humanoid") then
    --         target.Character.Humanoid.Health = 0
    --     end
    -- end)
end

-- ===== 寻找最近的目标 =====
local function GetClosestTarget()
    local character = LocalPlayer.Character
    if not character then return nil end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end

    local myPosition = rootPart.Position
    local closest = nil
    local shortestDist = Settings.Range

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                local dist = (myPosition - targetRoot.Position).Magnitude
                if dist <= Settings.Range then
                    -- 检查是否在白名单中
                    local isWhitelisted = false
                    for _, name in ipairs(Settings.Whitelist) do
                        if name == player.Name then
                            isWhitelisted = true
                            break
                        end
                    end
                    if not isWhitelisted and dist < shortestDist then
                        closest = player
                        shortestDist = dist
                    end
                end
            end
        end
    end
    return closest
end

-- ===== 创建 GUI 菜单 =====
local function CreateGUI()
    -- 清理旧 GUI
    local oldGui = CoreGui:FindFirstChild("WanzzKillAura")
    if oldGui then oldGui:Destroy() end

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "WanzzKillAura"
    screenGui.Parent = CoreGui

    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, 300, 0, 200)
    mainFrame.Position = UDim2.new(0.5, -150, 0.5, -100)
    mainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    mainFrame.BorderSizePixel = 0
    mainFrame.Parent = screenGui

    -- 标题
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 35)
    title.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
    title.Text = "WANZZ STORE | SOUTH BRONX"
    title.TextColor3 = Color3.fromRGB(255, 200, 50)
    title.Font = Enum.Font.SourceSansBold
    title.TextScaled = true
    title.Parent = mainFrame

    -- 启用按钮
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(0, 130, 0, 30)
    toggleBtn.Position = UDim2.new(0, 10, 0, 45)
    toggleBtn.Text = "Kill Aura: OFF"
    toggleBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggleBtn.Font = Enum.Font.SourceSans
    toggleBtn.TextSize = 14
    toggleBtn.Parent = mainFrame
    toggleBtn.MouseButton1Click:Connect(function()
        Settings.Enabled = not Settings.Enabled
        toggleBtn.Text = "Kill Aura: " .. (Settings.Enabled and "ON" or "OFF")
        toggleBtn.BackgroundColor3 = Settings.Enabled and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(50, 50, 70)
    end)

    -- 范围输入
    local rangeLabel = Instance.new("TextLabel")
    rangeLabel.Size = UDim2.new(0, 50, 0, 30)
    rangeLabel.Position = UDim2.new(0, 150, 0, 45)
    rangeLabel.BackgroundTransparency = 1
    rangeLabel.Text = "Range"
    rangeLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    rangeLabel.Font = Enum.Font.SourceSans
    rangeLabel.TextSize = 14
    rangeLabel.Parent = mainFrame

    local rangeBox = Instance.new("TextBox")
    rangeBox.Size = UDim2.new(0, 80, 0, 30)
    rangeBox.Position = UDim2.new(0, 200, 0, 45)
    rangeBox.Text = tostring(Settings.Range)
    rangeBox.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    rangeBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    rangeBox.Font = Enum.Font.SourceSans
    rangeBox.TextSize = 14
    rangeBox.Parent = mainFrame
    rangeBox.FocusLost:Connect(function()
        local val = tonumber(rangeBox.Text)
        if val and val > 0 then Settings.Range = val else rangeBox.Text = tostring(Settings.Range) end
    end)

    -- 信息显示
    local infoLabel = Instance.new("TextLabel")
    infoLabel.Size = UDim2.new(1, -20, 0, 30)
    infoLabel.Position = UDim2.new(0, 10, 0, 85)
    infoLabel.Text = "Players: 0 | Whitelist: 0"
    infoLabel.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    infoLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    infoLabel.Font = Enum.Font.SourceSans
    infoLabel.TextSize = 13
    infoLabel.Parent = mainFrame

    -- 白名单按钮
    local wlBtn = Instance.new("TextButton")
    wlBtn.Size = UDim2.new(0, 280, 0, 30)
    wlBtn.Position = UDim2.new(0, 10, 0, 125)
    wlBtn.Text = "Open Whitelist"
    wlBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    wlBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    wlBtn.Font = Enum.Font.SourceSans
    wlBtn.TextSize = 14
    wlBtn.Parent = mainFrame

    -- ==== 白名单弹窗 ====
    local popup = Instance.new("Frame")
    popup.Size = UDim2.new(0, 250, 0, 150)
    popup.Position = UDim2.new(0.5, -125, 0.5, -75)
    popup.BackgroundColor3 = Color3.fromRGB(25, 25, 40)
    popup.BorderSizePixel = 0
    popup.Visible = false
    popup.Parent = screenGui

    local popupTitle = Instance.new("TextLabel")
    popupTitle.Size = UDim2.new(1, 0, 0, 30)
    popupTitle.Text = "WHITELIST"
    popupTitle.BackgroundColor3 = Color3.fromRGB(60, 40, 80)
    popupTitle.TextColor3 = Color3.fromRGB(255, 200, 50)
    popupTitle.Font = Enum.Font.SourceSansBold
    popupTitle.TextScaled = true
    popupTitle.Parent = popup

    local wlList = Instance.new("ScrollingFrame")
    wlList.Size = UDim2.new(1, -20, 0, 60)
    wlList.Position = UDim2.new(0, 10, 0, 35)
    wlList.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    wlList.BorderSizePixel = 0
    wlList.Parent = popup

    local wlLayout = Instance.new("UIListLayout")
    wlLayout.SortOrder = Enum.SortOrder.Name
    wlLayout.Parent = wlList

    local function RefreshWhitelist()
        for _, child in ipairs(wlList:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        for _, name in ipairs(Settings.Whitelist) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 25)
            btn.Text = name .. " [x]"
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Font = Enum.Font.SourceSans
            btn.TextSize = 13
            btn.Parent = wlList
            btn.MouseButton1Click:Connect(function()
                for i, v in ipairs(Settings.Whitelist) do
                    if v == name then table.remove(Settings.Whitelist, i) break end
                end
                RefreshWhitelist()
            end)
        end
    end

    local addBox = Instance.new("TextBox")
    addBox.Size = UDim2.new(0, 130, 0, 25)
    addBox.Position = UDim2.new(0, 10, 0, 100)
    addBox.PlaceholderText = "Player Name"
    addBox.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    addBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    addBox.Font = Enum.Font.SourceSans
    addBox.TextSize = 13
    addBox.Parent = popup

    local addBtn = Instance.new("TextButton")
    addBtn.Size = UDim2.new(0, 80, 0, 25)
    addBtn.Position = UDim2.new(0, 150, 0, 100)
    addBtn.Text = "Add"
    addBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    addBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    addBtn.Font = Enum.Font.SourceSans
    addBtn.TextSize = 13
    addBtn.Parent = popup
    addBtn.MouseButton1Click:Connect(function()
        local name = addBox.Text
        if name ~= "" then
            local dup = false
            for _, v in ipairs(Settings.Whitelist) do if v == name then dup = true break end end
            if not dup then
                table.insert(Settings.Whitelist, name)
                RefreshWhitelist()
                addBox.Text = ""
            end
        end
    end)

    wlBtn.MouseButton1Click:Connect(function()
        RefreshWhitelist()
        popup.Visible = true
    end)

    -- 点击弹窗外关闭
    popup.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local pos = input.Position
            local absPos = popup.AbsolutePosition
            local size = popup.AbsoluteSize
            if not (pos.X >= absPos.X and pos.X <= absPos.X + size.X and pos.Y >= absPos.Y and pos.Y <= absPos.Y + size.Y) then
                popup.Visible = false
            end
        end
    end)

    -- ==== 主循环 (Heartbeat) ====
    local lastAttackTime = 0
    RunService.Heartbeat:Connect(function(deltaTime)
        -- 更新信息
        local count = 0
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local pos = char.HumanoidRootPart.Position
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (pos - player.Character.HumanoidRootPart.Position).Magnitude
                    if dist <= Settings.Range then count = count + 1 end
                end
            end
        end
        infoLabel.Text = "Players: " .. count .. " | Whitelist: " .. #Settings.Whitelist

        -- Kill Aura 逻辑
        if not Settings.Enabled then return end

        lastAttackTime = lastAttackTime + deltaTime
        if lastAttackTime < Settings.AttackRate then return end
        lastAttackTime = 0

        local target = GetClosestTarget()
        if target then
            Attack(target)
        end
    end)

    -- 拖动窗口
    local dragging, dragInput, dragStart, startPos
    mainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    mainFrame.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- ===== 启动脚本 =====
pcall(CreateGUI)
print("[WANZZ] South Bronx Kill Aura 已加载! 按 GUI 中的按钮启用。")
