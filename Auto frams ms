-- Anti-stuck checker
task.spawn(function()
    local lastCash, lastStatus, lastCashTime, lastStatusTime = 0, "", os.clock(), os.clock()
    task.wait(60)
    lastCash = GetCurrentCashAmount(); lastStatus = State.Status
    while task.wait(30) do
        if not ENABLE_AUTOFARM then
            lastCashTime=os.clock(); lastStatusTime=os.clock(); lastCash=GetCurrentCashAmount(); lastStatus=State.Status
            continue
        end
        local now, curCash = os.clock(), GetCurrentCashAmount()
        if curCash ~= lastCash then lastCash=curCash; lastCashTime=now end
        if State.Status ~= lastStatus then lastStatus=State.Status; lastStatusTime=now end
        if (now-lastCashTime)>=300 or (now-lastStatusTime)>=300 then DoRejoin(); return end
    end
end)

