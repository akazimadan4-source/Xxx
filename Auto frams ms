-- ==================== UTILITY FUNCTIONS ====================

-- Cari sepeda milik pemain
local function FindBike()
    for _, obj in Workspace:GetChildren() do
        if obj:FindFirstChild("Owner") and string.match(tostring(obj), LocalPlayer.Name .. "'s Car") then
            if obj:FindFirstChild("Body") and obj.Body:FindFirstChild("Passenger") then
                return obj
            end
        end
    end
    return nil
end

-- Teleport dengan mode yang dipilih
local function Teleport(destination)
    if Config.MovementType == "Bike" then
        local bike = FindBike()
        if not bike then
            Library:Notification("Bike", "Tidak menemukan sepeda, spawn dulu!", 3)
            return "Failed"
        end
        -- Pastikan pemain duduk di sepeda
        local seat = bike:FindFirstChild("DriveSeat")
        if not seat or seat.Occupant ~= LocalPlayer.Character and seat.Occupant ~= LocalPlayer.Character.Humanoid then
            Library:Notification("Bike", "Anda belum duduk di sepeda!", 3)
            return "Failed"
        end
        -- Teleport sepeda ke tujuan
        for _ = 1, 30 do
            bike:SetPrimaryPartCFrame(destination + Vector3.new(0, 1.5, 0))
        end
        task.wait(0.5)
        return "Success"
    else
        -- Safe Mode: teleport karakter langsung (dengan anti-fall)
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not root then return "Failed" end
        root.CFrame = destination
        task.wait(0.3)
        return "Success"
    end
end

-- Equip tool dari backpack
local function EquipTool(toolName)
    local character = LocalPlayer.Character
    if not character then return false end
    local hum = character:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    local tool = LocalPlayer.Backpack:FindFirstChild(toolName) or character:FindFirstChild(toolName)
    if tool then
        pcall(function() hum:EquipTool(tool) end)
        task.wait(0.3)
        return true
    end
    return false
end

-- Hitung jumlah item di backpack + tangan
local function CountItem(name)
    local count = 0
    for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if item.Name == name then count = count + 1 end
    end
    if LocalPlayer.Character then
        for _, item in ipairs(LocalPlayer.Character:GetChildren()) do
            if item:IsA("Tool") and item.Name == name then count = count + 1 end
        end
    end
    return count
end

-- Fire proximity prompt dengan aman
local function FirePrompt(prompt)
    if not prompt or not prompt:IsA("ProximityPrompt") then return false end
    pcall(function()
        prompt.HoldDuration = 0
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = 50
        prompt:InputHoldBegin()
        task.wait(0.05)
        prompt:InputHoldEnd()
    end)
    return true
end

-- Cari apartemen pribadi
local function GetPersonalApartment()
    local apts = Workspace.Map and Workspace.Map:FindFirstChild("APTS")
    if not apts then return nil end
    for _, apt in ipairs(apts:GetChildren()) do
        local board = apt:FindFirstChild("Board")
        if board then
            local label = board:FindFirstChild("name") and board.name:FindFirstChild("SurfaceGui")
            if label and label:FindFirstChild("TextLabel") then
                if label.TextLabel.Text == LocalPlayer.Name then
                    return apt
                end
            end
        end
    end
    return nil
end

-- Cari apartemen kosong
local function GetUnclaimedApartment()
    local apts = Workspace.Map and Workspace.Map:FindFirstChild("APTS")
    if not apts then return nil end
    for _, apt in ipairs(apts:GetChildren()) do
        local board = apt:FindFirstChild("Board")
        if board then
            local label = board:FindFirstChild("name") and board.name:FindFirstChild("SurfaceGui")
            if label and label:FindFirstChild("TextLabel") then
                if label.TextLabel.Text == "VACANT" then
                    return apt
                end
            end
        end
    end
    return nil
end

-- Dapatkan interior apartemen
local function GetHouseInterior()
    local apt = GetPersonalApartment()
    if not apt then return nil end
    local house = Workspace.Map.Houses:FindFirstChild(apt.Name) or Workspace.Map.Locations.Apartments:FindFirstChild(apt.Name)
    if house then
        return house:FindFirstChild("Interior") or house
    end
    return nil
end

-- Beli apartemen jika belum punya
local function BuyApartment()
    local apt = GetPersonalApartment()
    if apt then
        Library:Notification("Apartemen", "Sudah punya apartemen!", 3)
        return true
    end
    local vacant = GetUnclaimedApartment()
    if not vacant then
        Library:Notification("Apartemen", "Tidak ada apartemen kosong!", 3)
        return false
    end
    -- Teleport ke papan apartemen
    local board = vacant:FindFirstChild("Board")
    if not board then return false end
    local prompt = board:FindFirstChild("backboard") and board.backboard:FindFirstChildOfClass("ProximityPrompt")
    if not prompt then return false end
    Teleport(CFrame.new(board.Position))
    task.wait(0.5)
    FirePrompt(prompt)
    task.wait(1)
    Library:Notification("Apartemen", "Berhasil membeli apartemen!", 3)
    return true
end

-- Spawn sepeda
local function SpawnBike()
    local bike = FindBike()
    if bike then
        Library:Notification("Bike", "Sepeda sudah ada!", 3)
        return
    end
    local b = buffer.create(1)
    buffer.writeu8(b, 0, 1)
    ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("RPC"):FireServer(b, "Spawn", "DirtBike")
    task.wait(2)
    bike = FindBike()
    if bike then
        Library:Notification("Bike", "Sepeda berhasil di-spawn!", 3)
    else
        Library:Notification("Bike", "Gagal spawn sepeda!", 3)
    end
end

