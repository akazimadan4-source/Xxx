-- ==================== UTILITY FUNCTIONS ====================

local function FindBike()
    for _, obj in Workspace:GetChildren() do
        if obj:FindFirstChild("Owner") and string.match(tostring(obj), LocalPlayer.Name .. "'s Car") then
            if obj:FindFirstChild("Body") and obj.Body:FindFirstChild("Passenger") then
                return obj
            end
        end
    end
    return nil
end

local function Teleport(destination)
    if Config.MovementType == "Bike" then
        local bike = FindBike()
        if not bike then
            Library:Notification("Bike", "Tidak menemukan sepeda, spawn dulu!", 3)
            return "Failed"
        end
        local seat = bike:FindFirstChild("DriveSeat")
        if not seat or seat.Occupant ~= LocalPlayer.Character and seat.Occupant ~= LocalPlayer.Character.Humanoid then
            Library:Notification("Bike", "Anda belum duduk di sepeda!", 3)
            return "Failed"
        end
        for _ = 1, 30 do
            bike:SetPrimaryPartCFrame(destination + Vector3.new(0, 1.5, 0))
        end
        task.wait(0.5)
        return "Success"
    else
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not root then return "Failed" end
        root.CFrame = destination
        task.wait(0.3)
        return "Success"
    end
end

local function EquipTool(toolName)
    local character = LocalPlayer.Character
    if not character then return false end
    local hum = character:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    local tool = LocalPlayer.Backpack:FindFirstChild(toolName) or character:FindFirstChild(toolName)
    if tool then
        pcall(function() hum:EquipTool(tool) end)
        task.wait(0.3)
        return true
    end
    return false
end

local function CountItem(name)
    local count = 0
    for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if item.Name == name then count = count + 1 end
    end
    if LocalPlayer.Character then
        for _, item in ipairs(LocalPlayer.Character:GetChildren()) do
            if item:IsA("Tool") and item.Name == name then count = count + 1 end
        end
    end
    return count
end

local function FirePrompt(prompt)
    if not prompt or not prompt:IsA("ProximityPrompt") then return false end
    pcall(function()
        prompt.HoldDuration = 0
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = 50
        prompt:InputHoldBegin()
        task.wait(0.05)
        prompt:InputHoldEnd()
    end)
    return true
end

local function GetPersonalApartment()
    local apts = Workspace.Map and Workspace.Map:FindFirstChild("APTS")
    if not apts then return nil end
    for _, apt in ipairs(apts:GetChildren()) do
        local board = apt:FindFirstChild("Board")
        if board then
            local label = board:FindFirstChild("name") and board.name:FindFirstChild("SurfaceGui")
            if label and label:FindFirstChild("TextLabel") then
                if label.TextLabel.Text == LocalPlayer.Name then
                    return apt
                end
            end
        end
    end
    return nil
end

local function GetUnclaimedApartment()
    local apts = Workspace.Map and Workspace.Map:FindFirstChild("APTS")
    if not apts then return nil end
    for _, apt in ipairs(apts:GetChildren()) do
        local board = apt:FindFirstChild("Board")
        if board then
            local label = board:FindFirstChild("name") and board.name:FindFirstChild("SurfaceGui")
            if label and label:FindFirstChild("TextLabel") then
                if label.TextLabel.Text == "VACANT" then
                    return apt
                end
            end
        end
    end
    return nil
end

local function GetHouseInterior()
    local apt = GetPersonalApartment()
    if not apt then return nil end
    local house = Workspace.Map.Houses:FindFirstChild(apt.Name) or Workspace.Map.Locations.Apartments:FindFirstChild(apt.Name)
    if house then
        return house:FindFirstChild("Interior") or house
    end
    return nil
end

local function BuyApartment()
    local apt = GetPersonalApartment()
    if apt then
        Library:Notification("Apartemen", "Sudah punya apartemen!", 3)
        return true
    end
    local vacant = GetUnclaimedApartment()
    if not vacant then
        Library:Notification("Apartemen", "Tidak ada apartemen kosong!", 3)
        return false
    end
    local board = vacant:FindFirstChild("Board")
    if not board then return false end
    local prompt = board:FindFirstChild("backboard") and board.backboard:FindFirstChildOfClass("ProximityPrompt")
    if not prompt then return false end
    Teleport(CFrame.new(board.Position))
    task.wait(0.5)
    FirePrompt(prompt)
    task.wait(1)
    Library:Notification("Apartemen", "Berhasil membeli apartemen!", 3)
    return true
end

local function SpawnBike()
    local bike = FindBike()
    if bike then
        Library:Notification("Bike", "Sepeda sudah ada!", 3)
        return
    end
    local b = buffer.create(1)
    buffer.writeu8(b, 0, 1)
    ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("RPC"):FireServer(b, "Spawn", "DirtBike")
    task.wait(2)
    bike = FindBike()
    if bike then
        Library:Notification("Bike", "Sepeda berhasil di-spawn!", 3)
    else
        Library:Notification("Bike", "Gagal spawn sepeda!", 3)
    end
end

local function GoToSafeZone()
    Teleport(Config.SafeZonePosition)
    task.wait(1)
end

-- ==================== MARSHMALLOW FARM CORE ====================
local Items = {"Gelatin", "Sugar Block Bag", "Water"}
local ItemPrices = {Gelatin = 70, ["Sugar Block Bag"] = 100, Water = 20}
local MarshmallowSellPrice = {
    ["Small Marshmallow Bag"] = 1470,
    ["Medium Marshmallow Bag"] = 2840,
    ["Large Marshmallow Bag"] = 4050,
}
local MarshmallowNames = {"Small Marshmallow Bag", "Medium Marshmallow Bag", "Large Marshmallow Bag"}

local function GetMarshmallowType(name)
    for _, m in ipairs(MarshmallowNames) do
        if m == name then return m end
    end
    return nil
end

local function BuyIngredients()
    local needed = Config.BatchAmount
    local crafted = 0
    for _, m in ipairs(MarshmallowNames) do
        crafted = crafted + CountItem(m)
    end
    local toMake = math.max(needed - crafted, 0)
    if toMake <= 0 then return true end

    for _, item in ipairs(Items) do
        local have = CountItem(item)
        local need = toMake - have
        if need > 0 then
            for _ = 1, need do
                ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("StorePurchase"):FireServer(item)
                Stats.Earned = Stats.Earned - ItemPrices[item]
                task.wait(0.3)
            end
        end
    end
    return true
end

local function CookCycle()
    local apt = GetPersonalApartment()
    if not apt then
        Library:Notification("Apartemen", "Belum punya apartemen, membeli...", 3)
        if not BuyApartment() then
            Library:Notification("Error", "Gagal membeli apartemen!", 3)
            return false
        end
        apt = GetPersonalApartment()
        if not apt then return false end
    end

    local interior = GetHouseInterior()
    if not interior then return false end
    local pot = interior:FindFirstChild("Cooking Pot") or interior:FindFirstChild("Stove")
    if not pot then
        Library:Notification("Error", "Tidak menemukan kompor!", 3)
        return false
    end

    Teleport(pot.CFrame)
    task.wait(0.5)

    local function DoStep(stepName, toolName, waitText, delay)
        if stepName == "Water" then
            if not EquipTool("Water") then
                Library:Notification("Error", "Tidak ada Water!", 3)
                return false
            end
            FirePrompt(pot.Attachment.ProximityPrompt)
            task.wait(2)
            local timeout = 0
            repeat
                task.wait(0.5)
                timeout = timeout + 0.5
                if timeout > 30 then break end
            until Task_Text == "Wait 20 seconds for your water to boil."
            task.wait(20)
            LocalPlayer.Character.Humanoid:UnequipTools()
            MarshMallowStep = "Sugar"
        elseif stepName == "Sugar" then
            if not EquipTool("Sugar Block Bag") then
                Library:Notification("Error", "Tidak ada Sugar Block Bag!", 3)
                return false
            end
            FirePrompt(pot.Attachment.ProximityPrompt)
            task.wait(2)
            local timeout = 0
            repeat
                task.wait(0.5)
                timeout = timeout + 0.5
                if timeout > 30 then break end
            until Task_Text == "Pour gelatin into the pot."
            LocalPlayer.Character.Humanoid:UnequipTools()
            MarshMallowStep = "Gelatin"
        elseif stepName == "Gelatin" then
            if not EquipTool("Gelatin") then
                Library:Notification("Error", "Tidak ada Gelatin!", 3)
                return false
            end
            FirePrompt(pot.Attachment.ProximityPrompt)
            task.wait(2)
            local timeout = 0
            repeat
                task.wait(0.5)
                timeout = timeout + 0.5
                if timeout > 30 then break end
            until Task_Text == "Let the solution cook for 45 seconds."
            task.wait(45)
            LocalPlayer.Character.Humanoid:UnequipTools()
            MarshMallowStep = "Collect"
        elseif stepName == "Collect" then
            if not EquipTool("Empty Bag") then
                Library:Notification("Error", "Tidak ada Empty Bag!", 3)
                return false
            end
            FirePrompt(pot.Attachment.ProximityPrompt)
            task.wait(2)
            local timeout = 0
            repeat
                task.wait(0.5)
                timeout = timeout + 0.5
                if timeout > 10 then break end
            until not LocalPlayer.Character:FindFirstChild("Empty Bag")
            LocalPlayer.Character.Humanoid:UnequipTools()
            MarshMallowStep = "Sell"
        end
        return true
    end

    local steps = {"Water", "Sugar", "Gelatin", "Collect"}
    for _, step in ipairs(steps) do
        if not IsRunning then return false end
        if not DoStep(step) then return false end
    end
    return true
end

local function SellMarshmallows()
    Teleport(Config.SafeZonePosition)
    task.wait(1)
    local npc = Workspace.Folders and Workspace.Folders.NPCs and Workspace.Folders.NPCs:FindFirstChild("Lamont Bell")
    if not npc then
        Library:Notification("Error", "NPC Lamont Bell tidak ditemukan!", 3)
        return false
    end
    local prompt = npc.UpperTorso:FindFirstChildOfClass("ProximityPrompt")
    if not prompt then return false end

    for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local mType = GetMarshmallowType(tool.Name)
            if mType then
                EquipTool(tool.Name)
                FirePrompt(prompt)
                Stats.Earned = Stats.Earned + MarshmallowSellPrice[mType]
                Stats.TotalSold = Stats.TotalSold + 1
                if mType == "Small Marshmallow Bag" then Stats.Small = Stats.Small + 1
                elseif mType == "Medium Marshmallow Bag" then Stats.Medium = Stats.Medium + 1
                elseif mType == "Large Marshmallow Bag" then Stats.Large = Stats.Large + 1
                end
                task.wait(0.3)
            end
        end
    end
    MarshMallowStep = "Water"
    return true
end

local function FarmLoop()
    while IsRunning do
        BuyIngredients()
        CookCycle()
        SellMarshmallows()
        GoToSafeZone()
        task.wait(1)
    end
end

local function StartFarm()
    if IsRunning then return end
    IsRunning = true
    MarshMallowStep = "Water"
    if Config.MovementType == "Bike" then
        local bike = FindBike()
        if not bike then
            Library:Notification("Bike", "Tidak ada sepeda, spawn sekarang...", 3)
            SpawnBike()
            task.wait(2)
            bike = FindBike()
            if not bike then
                Library:Notification("Error", "Gagal spawn sepeda, gunakan Safe Mode!", 3)
                IsRunning = false
                return
            end
        end
        local seat = bike:FindFirstChild("DriveSeat")
        if seat then
            local prompt = seat:FindFirstChild("Attachment") and seat.Attachment:FindFirstChildOfClass("ProximityPrompt")
            if prompt then
                FirePrompt(prompt)
                task.wait(1)
            end
        end
    end
    FarmThread = task.spawn(FarmLoop)
    Library:Notification("Farm", "Marshmallow Farm dimulai!", 3)
end

local function StopFarm()
    IsRunning = false
    if FarmThread then
        task.cancel(FarmThread)
        FarmThread = nil
    end
    Library:Notification("Farm", "Marshmallow Farm dihentikan!", 3)
end

