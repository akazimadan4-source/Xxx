local function ConnectDeathHandler(char)
    local hum = char:WaitForChild("Humanoid",5)
    if hum then hum.Died:Connect(function()
        if State.RespawnPending then return end
        if ENABLE_AUTOFARM and AUTO_ANTI_DEATH then task.wait(3); DoRejoin() end
    end) end
end
